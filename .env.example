# ============================================================
# VEXHALIA — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# At minimum, you need ONE of the LLM provider keys below.
# ============================================================

# --- LLM Provider ---
# Choose your provider: "groq" (free) or "openai" (paid)
LLM_PROVIDER=groq

# Groq API Key (free at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# OpenAI API Key (optional, paid — https://platform.openai.com)
OPENAI_API_KEY=

# --- Feature Flags ---
# Set to "true" to use mock data instead of live APIs
# Useful for development or when APIs are unavailable
USE_MOCK_WEATHER=false
USE_MOCK_IMAGES=false
USE_MOCK_SEARCH=false
